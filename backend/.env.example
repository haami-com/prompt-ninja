OPENROUTER_API_KEY=
# The OpenRouter model ID to select until the live model catalogue loads.
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash
# Optional comma-separated restriction for the council UI. Leave blank to show
# every OpenRouter model that can produce text output.
OPENROUTER_ALLOWED_MODELS=
# Optional attribution shown in the OpenRouter dashboard and rankings.
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Prompt Ninja
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
